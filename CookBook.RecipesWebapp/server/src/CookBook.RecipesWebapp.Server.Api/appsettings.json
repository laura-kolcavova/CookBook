{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "System": "Warning",
      "Microsoft": "Warning"
    }
  },

  "AllowedHosts": "*",

  "SpaClientConfiguration": {
    "IsSpaEnabled": true,
    "StaticFilesRootPath": "client/build",
    "UseDevelopmentProxyServer": false
  },

  "OpenIdConnectAppConfiguration": {
    "Authority": "http://host.docker.internal:8020",
    "ClientId": "CookBook.RecipesWebApp",
    "ClientSecret": "c0741d5c-f119-4b19-be90-08b6bd1084bf"
  },

  "ReverseProxyConfiguration": {
    "HttpRequest": {
      "ActivityTimeout": "00:00:30",
      "Version": "1.1",
      "VersionPolicy": "RequestVersionOrHigher",
      "AllowResponseBuffering": "false"
    },
    "Routes": {
      "RecipeApiGetLatestRecipesRoute": {
        "ClusterId": "RecipesApi",
        "AuthorizationPolicy": "anonymous",
        "Match": {
          "Path": "/api/recipes/latest",
          "Methods": [
            "GET"
          ]
        },
        "MetaData": {
        },
        "Transforms": [
          {
            "PathPattern": "/api/recipes/latest"
          },
          {
            "RequestHeaderOriginalHost": "false"
          }
        ]
      },
      "RecipeApiGetRecipeDetailRoute": {
        "ClusterId": "RecipesApi",
        "AuthorizationPolicy": "anonymous",
        "Match": {
          "Path": "/api/recipes/{recipeId}/detail",
          "Methods": [
            "GET"
          ]
        },
        "MetaData": {
        },
        "Transforms": [
          {
            "PathPattern": "/api/recipes/{recipeId}/detail"
          },
          {
            "RequestHeaderOriginalHost": "false"
          }
        ]
      },
      "RecipesApiSearchRecipesRoute": {
        "ClusterId": "RecipesApi",
        "AuthorizationPolicy": "anonymous",
        "Match": {
          "Path": "/api/recipes/search",
          "Methods": [
            "GET"
          ]
        },
        "MetaData": {
        },
        "Transforms": [
          {
            "PathPattern": "/api/recipes/search"
          },
          {
            "RequestHeaderOriginalHost": "false"
          }
        ]
      },
      "RecipeApiSaveRecipeRoute": {
        "ClusterId": "RecipesApi",
        "AuthorizationPolicy": "CookieAuthenticationPolicy",
        "Match": {
          "Path": "/api/recipes/save",
          "Methods": [
            "PUT"
          ]
        },
        "MetaData": {
          "OpenIdConnectScopes": "CookBook.RecipesApi.Save"
        },
        "Transforms": [
          {
            "PathPattern": "/api/recipes/save"
          },
          {
            "RequestHeaderOriginalHost": "false"
          }
        ]
      },
      "RecipeApiRenoveRecipeRoute": {
        "ClusterId": "RecipesApi",
        "AuthorizationPolicy": "CookieAuthenticationPolicy",
        "Match": {
          "Path": "/api/recipes/{recipeId}/remove",
          "Methods": [
            "DELETE"
          ]
        },
        "MetaData": {
        },
        "Transforms": [
          {
            "PathPattern": "/api/recipes/{recipeId}/remove"
          },
          {
            "RequestHeaderOriginalHost": "false"
          }
        ]
      }
    },
    "Clusters": {
      "RecipesApi": {
        "Destinations": {
          "main": {
            "Address": "http://host.docker.internal:8010"
          }
        },
        "MetaData": {
          "OpenApiDocumentUrl": "/.less-known/api-docs/v1.json"
        }
      }
    }
  }
}
