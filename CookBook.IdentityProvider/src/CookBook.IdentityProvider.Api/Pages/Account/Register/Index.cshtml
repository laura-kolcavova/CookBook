@page

@using CookBook.IdentityProvider.Api.Pages.Account.Register;

@model IndexModel

@{
    ViewData["Title"] = "Register";
}

<div class="flex min-h-screen">
    <div class="hidden lg:block lg:w-1/2">
        <img src='~/images/login_side_panel_image.png' alt="A vibrant dish of food" class="object-cover w-full h-full" />
    </div>

    <div class="w-full lg:w-1/2 flex items-center justify-center p-8 bg-gray-100">
        <div class="w-full max-w-md bg-white p-8 rounded-lg shadow-lg">
            <h2 class="text-2xl font-bold text-center text-gray-800 mb-6">Create an Account</h2>

            <form method="post">
                <div asp-validation-summary="ModelOnly" class="text-red-500 text-sm mb-4"></div>

                <div class="mb-4">
                    <label asp-for="Input.DisplayName" class="block text-gray-700 text-sm font-bold mb-2">Display Name</label>
                    <input asp-for="Input.DisplayName" class="shadow appearance-none border rounded w-full py-2 px-3 text-gray-700 leading-tight focus:outline-none focus:shadow-outline" autofocus />
                    <span asp-validation-for="Input.DisplayName" class="text-red-500 text-xs italic"></span>
                </div>

                <div class="mb-4">
                    <label asp-for="Input.Email" class="block text-gray-700 text-sm font-bold mb-2">Email Address</label>
                    <input asp-for="Input.Email" class="shadow appearance-none border rounded w-full py-2 px-3 text-gray-700 leading-tight focus:outline-none focus:shadow-outline" />
                    <span asp-validation-for="Input.Email" class="text-red-500 text-xs italic"></span>
                </div>

                <div class="mb-6">
                    <label asp-for="Input.Password" class="block text-gray-700 text-sm font-bold mb-2">Password</label>
                    <input asp-for="Input.Password" class="shadow appearance-none border rounded w-full py-2 px-3 text-gray-700 mb-3 leading-tight focus:outline-none focus:shadow-outline" />
                    <span asp-validation-for="Input.Password" class="text-red-500 text-xs italic"></span>
                </div>

                <div class="mb-6">
                    <label asp-for="Input.ConfirmPassword" class="block text-gray-700 text-sm font-bold mb-2">Confirm Password</label>
                    <input asp-for="Input.ConfirmPassword" class="shadow appearance-none border rounded w-full py-2 px-3 text-gray-700 mb-3 leading-tight focus:outline-none focus:shadow-outline" />
                    <span asp-validation-for="Input.ConfirmPassword" class="text-red-500 text-xs italic"></span>
                </div>

                <input type="hidden" asp-for="Input.ReturnUrl" />

                <div class="flex items-center justify-between">
                    <button type="submit" class="bg-blue-500 hover:bg-blue-700 text-white font-bold py-2 px-4 rounded focus:outline-none focus:shadow-outline w-full">
                        Register
                    </button>
                </div>
            </form>

            <div class="text-center mt-6 text-base ">
                Already have an account? <a asp-page="/Account/LogIn/Index" class="text-blue-500 hover:text-blue-700">Log in</a>
            </div>
        </div>
    </div>
</div>
